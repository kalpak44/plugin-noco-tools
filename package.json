{
  "name": "@kalpak44/plugin-noco-tools",
  "version": "0.1.0",
  "description": "NocoBase plugin — connect NocoBase (and its AI employees) to Gmail and Google Calendar via user-consented OAuth. Adds a Connect-Google block, a public OAuth callback endpoint, token rotation, REST tools, and AI-plugin tool registration.",
  "displayName": "Noco Tools — Google (Gmail + Calendar)",
  "keywords": [
    "nocobase",
    "nocobase-plugin",
    "google",
    "gmail",
    "google-calendar",
    "oauth",
    "ai-tools"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kalpak44/plugin-noco-tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/kalpak44/plugin-noco-tools.git"
  },
  "bugs": {
    "url": "https://github.com/kalpak44/plugin-noco-tools/issues"
  },
  "main": "dist/server/index.js",
  "module": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "files": [
    "dist",
    "client-v2.js",
    "client-v2.d.ts",
    "server.js",
    "server.d.ts",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "bootstrap": "bash scripts/bootstrap-dev-app.sh",
    "build": "bash scripts/build-tgz.sh",
    "build:only": "bash scripts/build-only.sh",
    "dev": "bash scripts/dev.sh",
    "clean": "rm -rf dist client-v2.js client-v2.d.ts client.js client.d.ts server.js server.d.ts"
  },
  "peerDependencies": {
    "@nocobase/client-v2": ">=1.6.0",
    "@nocobase/database": ">=1.6.0",
    "@nocobase/flow-engine": ">=1.6.0",
    "@nocobase/server": ">=1.6.0",
    "antd": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}