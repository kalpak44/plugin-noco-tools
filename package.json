{
  "name": "@kalpak44/plugin-noco-tools",
  "version": "0.1.19",
  "description": "NocoBase plugin that connects NocoBase AI employees to external services. Currently includes connectors for Gmail and Google Calendar — more connectors coming.",
  "displayName": "Noco AI Tools",
  "keywords": [
    "nocobase",
    "nocobase-plugin",
    "google",
    "gmail",
    "google-calendar",
    "oauth",
    "ai-tools"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kalpak44/plugin-noco-tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/kalpak44/plugin-noco-tools.git"
  },
  "bugs": {
    "url": "https://github.com/kalpak44/plugin-noco-tools/issues"
  },
  "main": "dist/server/index.js",
  "module": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "nocobase": {
    "defaultEnabled": false,
    "supportedVersions": [
      "2.1.28"
    ],
    "editionLevel": 0
  },
  "files": [
    "dist",
    "client.js",
    "client.d.ts",
    "client-v2.js",
    "client-v2.d.ts",
    "server.js",
    "server.d.ts",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "bash scripts/build.sh",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@nocobase/client-v2": "2.1.28",
    "@nocobase/database": "2.1.28",
    "@nocobase/flow-engine": "2.1.28",
    "@nocobase/server": "2.1.28",
    "@nocobase/utils": "2.1.28",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
